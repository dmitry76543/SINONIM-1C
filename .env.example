# SYNC_SRC_OFFER=OfferArtNo
# SYNC_SRC_AMOUNT=Amount
# SYNC_SRC_PRICE=Price
# SYNC_DST_ARTNO=ArtNo
# SYNC_DST_OFFER=MultiOffer
# SYNC_DST_AMOUNT=Amount
# SYNC_DST_PRICE=Price
