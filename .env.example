# AdvantShop (shop.synonym-jewelry.ru)
ADVANTSHOP_BASE_URL=https://shop.synonym-jewelry.ru
ADVANTSHOP_SERVER_API_KEY=your_server_api_key
# Или полный URL со страницы «Настройки → API → 1C → Импорт товаров»:
# ADVANTSHOP_1C_IMPORT_URL=https://shop.synonym-jewelry.ru/api/1c/importproducts?apikey=...

# FTP (файл от 1С) — выгрузка 6–22 МСК каждый час
FTP_HOST=95.79.55.253
FTP_USER=sinonim
FTP_PASSWORD=secret
FTP_REMOTE_PATH=/stocks.csv
FTP_PORT=2131
FTP_SECURE=false

# Выход в AdvantShop:
# multioffer (по умолчанию) — CSV 1.0 для /api/1c/importproducts
#   ArtNo;MultiOffer  →  [offer:size:color:price:purchase:amount]
# columns — плоские колонки как в ручном CSV 2.0 (API 1C их не понимает)
# SYNC_OUT_FORMAT=multioffer
# SYNC_POST_MODE=multipart
# SYNC_SKIP_IF_UNCHANGED=true
